GEMINI_API_KEY=your_google_api_key_here
MODEL=gemini/gemini-2.5-flash

# External publisher (private link, no login): ?view=publisher&key=YOUR_SECRET
PUBLISHER_SHARED_KEY=change_me_long_random_string
# Comma-separated fragments matched against client company_name (case-insensitive)
PUBLISHER_QUEUE_CLIENTS=alberton tyre clinic,alberton battery mart
